<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="pos_payment_method_view_form_inherit_credit_sale" model="ir.ui.view">
    <field name="name">pos.payment.method.form.inherit.credit.sale</field>
    <field name="model">pos.payment.method</field>
    <field name="inherit_id" ref="point_of_sale.pos_payment_method_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='split_transactions']" position="after">
        <field name="is_credit_sale" string="Es cuenta corriente"/>
      </xpath>
    </field>
  </record>
</odoo>
