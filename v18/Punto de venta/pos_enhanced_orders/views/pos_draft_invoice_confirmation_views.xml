<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_draft_invoice_confirmation_wizard_form_view" model="ir.ui.view">
        <field name="name">pos.draft.invoice.confirmation.wizard.form</field>
        <field name="model">pos.draft.invoice.confirmation.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmación de facturas del POS" create="0" edit="0" delete="0">
                <sheet class="o_pos_draft_invoice_confirmation_wizard">
                    <div class="o_pos_draft_invoice_summary">
                        <div class="o_pos_draft_invoice_summary_col">
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Sesión</span>
                                <field name="session_name" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Total</span>
                                <field name="total_count" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Pendientes</span>
                                <field name="pending_count" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                        <div class="o_pos_draft_invoice_summary_col">
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Conciliadas</span>
                                <field name="done_count" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Con error</span>
                                <field name="error_count" nolabel="1" readonly="1"/>
                            </div>
                            <div class="o_pos_draft_invoice_summary_item">
                                <span class="o_pos_draft_invoice_summary_label">Eliminadas</span>
                                <field name="deleted_count" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning mb-3" role="alert" invisible="can_continue">
                        Antes de cerrar la sesión tiene que emitir, conciliar o revisar manualmente todas las facturas del POS que sigan pendientes.
                    </div>
                    <div class="alert alert-success mb-3" role="alert" invisible="not can_continue">
                        No quedan facturas del POS pendientes. Ya puede continuar con el cierre de la sesión.
                    </div>

                    <div class="o_pos_draft_invoice_confirmation_table_wrap">
                        <field name="line_ids" nolabel="1">
                            <list create="0" delete="0" decoration-danger="emit_state == 'error'" decoration-success="emit_state == 'done'" decoration-muted="emit_state == 'deleted'">
                                <field name="emit_state" string="Resultado" widget="badge"/>
                                <field name="can_emit" column_invisible="1"/>
                                <field name="can_pay" column_invisible="1"/>
                                <field name="can_delete" column_invisible="1"/>
                                <field name="can_view" column_invisible="1"/>
                                <field name="line_type" column_invisible="1"/>
                                <field name="has_error_message" column_invisible="1"/>
                                <field name="has_pos_payment_drivers" column_invisible="1"/>
                                <field name="payment_action_label" column_invisible="1"/>
                                <field name="order_name" string="Orden"/>
                                <field name="invoice_name" string="Factura"/>
                                <field name="amount_total" string="Total" widget="monetary"/>
                                <field name="invoice_state_label" string="Estado"/>
                                <field name="cae_display" string="CAE"/>
                                <field name="message_display" string="Mensaje" widget="pos_draft_invoice_message"/>
                                <field name="action_display" string="" widget="pos_draft_invoice_actions"/>
                            </list>
                        </field>
                    </div>
                </sheet>
                <footer>
                    <button name="action_refresh_lines" type="object" string="Actualizar" class="btn-secondary"/>
                    <button name="action_continue_session_closing" type="object" string="Continuar con el cierre" class="btn-primary" invisible="not can_continue"/>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="pos_draft_invoice_error_wizard_form_view" model="ir.ui.view">
        <field name="name">pos.draft.invoice.error.wizard.form</field>
        <field name="model">pos.draft.invoice.error.wizard</field>
        <field name="arch" type="xml">
            <form string="Detalle del error" create="0" edit="0" delete="0">
                <sheet>
                    <group col="3">
                        <field name="order_name" string="Orden" readonly="1"/>
                        <field name="invoice_name" string="Factura" readonly="1"/>
                        <field name="last_attempt_at" string="Último intento" readonly="1"/>
                    </group>
                    <group>
                        <field name="error_message" string="Detalle" nolabel="1" readonly="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
