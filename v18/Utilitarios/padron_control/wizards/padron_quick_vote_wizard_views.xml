<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_padron_quick_vote_wizard_form" model="ir.ui.view">
        <field name="name">padron.quick.vote.wizard.form</field>
        <field name="model">padron.quick.vote.wizard</field>
        <field name="arch" type="xml">
            <form string="Marcar Voto (Rápido)">
                <sheet>
                    <group>
                        <field name="event_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_quick_create': True}"/>
                        <field name="identifier" placeholder="Ingresá DNI o Trámite y presioná Enter" options="{'no_create': True}"/>
                        <field name="person_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_quick_create': True}"/>
                        <field name="mesa_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_quick_create': True}"/>
                        <field name="vote_status" readonly="1"/>
                        <field name="vehicle_id" readonly="1" options="{'no_open': True, 'no_create': True, 'no_quick_create': True}"/>
                    </group>
                    <footer>
                        <button name="action_mark" type="object" string="Marcar Votó" class="btn-primary"/><button name="action_clear" type="object" string="Limpiar" class="btn-secondary"/></footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
