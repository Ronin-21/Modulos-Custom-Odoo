<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_padron_vehicle_assign_wizard_form" model="ir.ui.view">
        <field name="name">padron.vehicle.assign.wizard.form</field>
        <field name="model">padron.vehicle.assign.wizard</field>
        <field name="arch" type="xml">
            <form string="Asignar personas">
                <sheet>
                    <group>
                        <field name="vehicle_id" readonly="1"/>
                        <field name="replace_current"/>
                        <field name="partner_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Aplicar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
