<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_vehicle_form_padron_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.padron.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="priority">90</field>
        <field name="arch" type="xml">

            <!-- Botones/contadores arriba -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_padron_persons"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-users"
                        groups="padron_control.group_padron_operator,padron_control.group_padron_supervisor,padron_control.group_padron_admin">
                    <field name="padron_person_count" widget="statinfo" string="Asignados"/>
                </button>

                <button name="action_view_padron_persons_voted"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-check"
                        groups="padron_control.group_padron_operator,padron_control.group_padron_supervisor,padron_control.group_padron_admin">
                    <field name="padron_voted_count" widget="statinfo" string="Votaron"/>
                </button>

                <button name="action_view_padron_persons_not_voted"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-clock-o"
                        groups="padron_control.group_padron_operator,padron_control.group_padron_supervisor,padron_control.group_padron_admin">
                    <field name="padron_not_voted_count" widget="statinfo" string="Faltan"/>
                </button>
            </xpath>

            <!-- Pestaña Padrón dentro del vehículo -->
            <xpath expr="//sheet//notebook" position="inside">
                <page string="Padrón" name="padron_page"
                      groups="padron_control.group_padron_operator,padron_control.group_padron_supervisor,padron_control.group_padron_admin">
            <div class="o_row">
                <div class="o_col-12">
                    <button name="action_open_padron_assign_wizard" type="object"
                            string="Asignar personas" icon="fa-user-plus"
                            class="btn-primary"/>
                </div>
            </div>

                    <field name="padron_person_ids" readonly="1" nolabel="1" domain="[('is_padron_person','=',True)]">
                        <list create="false" edit="false" delete="false">
                        <field name="name" string="Nombre"/>
                        <field name="dni" string="DNI"/>
                        <field name="tramite" string="Trámite"/>
                        <field name="mesa_id" string="Mesa"/>
</list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
