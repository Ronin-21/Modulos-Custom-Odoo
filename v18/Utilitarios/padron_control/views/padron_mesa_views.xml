<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_padron_mesa_tree" model="ir.ui.view">
        <field name="name">padron.mesa.tree</field>
        <field name="model">padron.mesa</field>
        <field name="arch" type="xml">
            <list>
                <field name="number"/>
                <field name="zone"/>
            </list>
        </field>
    </record>

    <record id="view_padron_mesa_form" model="ir.ui.view">
        <field name="name">padron.mesa.form</field>
        <field name="model">padron.mesa</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="number"/>
                        <field name="zone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_padron_mesa" model="ir.actions.act_window">
        <field name="name">Mesas</field>
            <field name="groups_id" eval="[(4, ref('padron_control.group_padron_supervisor')), (4, ref('padron_control.group_padron_admin'))]"/>
        <field name="res_model">padron.mesa</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_padron_mesas" name="Mesas" parent="padron_control.menu_padron_config" action="action_padron_mesa" sequence="10"/>
</odoo>
