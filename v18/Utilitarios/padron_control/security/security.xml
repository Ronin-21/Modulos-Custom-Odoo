<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Groups -->
    <record id="module_category_padron" model="ir.module.category">
        <field name="name">Padrón Electoral</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_padron_operator" model="res.groups">
        <field name="name">Operador Padrón</field>
        <field name="category_id" ref="module_category_padron"/>
    </record>

    <record id="group_padron_supervisor" model="res.groups">
        <field name="name">Supervisor Padrón</field>
        <field name="category_id" ref="module_category_padron"/>
    </record>

    <record id="group_padron_admin" model="res.groups">
        <field name="name">Administrador Padrón</field>
        <field name="category_id" ref="module_category_padron"/>
    </record>

    <!-- Record Rules: Res Partner (solo padrón y solo mesas asignadas) -->
    <record id="rule_padron_partner_operator" model="ir.rule">
        <field name="name">Padrón - Personas por mesas (Operador/Supervisor)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">[ '|', ('is_padron_person','=',False), '&amp;', ('is_padron_person','=',True), ('mesa_id','in', user.mesa_ids.ids) ]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_operator')), (4, ref('padron_control.group_padron_supervisor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_padron_partner_admin" model="ir.rule">
        <field name="name">Padrón - Personas (Admin)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_admin'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- Record Rules: Checkin -->
    <record id="rule_padron_checkin_operator" model="ir.rule">
        <field name="name">Padrón - Checkin por mesas (Operador/Supervisor)</field>
        <field name="model_id" ref="padron_control.model_padron_checkin"/>
        <field name="domain_force">[('person_id.mesa_id','in', user.mesa_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_operator')), (4, ref('padron_control.group_padron_supervisor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_padron_checkin_admin" model="ir.rule">
        <field name="name">Padrón - Checkin (Admin)</field>
        <field name="model_id" ref="padron_control.model_padron_checkin"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_admin'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <!-- Record Rules: Transport -->
    <record id="rule_padron_transport_operator" model="ir.rule">
        <field name="name">Padrón - Traslado por mesas (Operador/Supervisor)</field>
        <field name="model_id" ref="padron_control.model_padron_transport_line"/>
        <field name="domain_force">[('person_id.mesa_id','in', user.mesa_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_operator')), (4, ref('padron_control.group_padron_supervisor'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_padron_transport_admin" model="ir.rule">
        <field name="name">Padrón - Traslado (Admin)</field>
        <field name="model_id" ref="padron_control.model_padron_transport_line"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('padron_control.group_padron_admin'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

<!-- Record Rule: Fleet Vehicle (permitir lectura desde Padrón para asignación) -->
<record id="rule_padron_fleet_vehicle_read" model="ir.rule">
    <field name="name">Padrón - Lectura de Vehículos</field>
    <field name="model_id" ref="fleet.model_fleet_vehicle"/>
    <field name="domain_force">[(1,'=',1)]</field>
    <field name="groups" eval="[(4, ref('padron_control.group_padron_operator')), (4, ref('padron_control.group_padron_supervisor')), (4, ref('padron_control.group_padron_admin'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="0"/>
    <field name="perm_create" eval="0"/>
    <field name="perm_unlink" eval="0"/>
</record>

</odoo>
