<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Hace readonly las líneas de la NC cuando fueron ajustadas automáticamente
            por el módulo (sidc_lines_locked = True).

            La condición original era: readonly="state != 'draft'"
            La nueva condición agrega: or sidc_lines_locked

            Esto bloquea la edición aunque la NC esté en borrador, preservando
            las cantidades calculadas automáticamente por el sistema.
        -->
        <record id="view_move_form_sidc_lines_lock" model="ir.ui.view">
            <field name="name">account.move.form.sidc.lines.lock</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath
                    expr="//field[@name='invoice_line_ids'][@widget='product_label_section_and_note_field_o2m']"
                    position="attributes">
                    <attribute name="readonly">state != 'draft' or sidc_lines_locked</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
