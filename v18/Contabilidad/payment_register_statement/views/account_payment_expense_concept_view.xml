<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_payment_form_prs_expense_concept" model="ir.ui.view">
        <field name="name">account.payment.form.prs.expense.concept</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <!-- Ubicar el campo en la columna derecha, debajo del último campo del bloque (normalmente 'Vendedor')
                 y, si no existe, debajo de 'Cuenta bancaria de proveedor'.
                 Esto evita que el campo quede al final del formulario. -->
            <xpath expr="(//sheet//field[@name='user_id' or @name='partner_bank_id'])[last()]" position="after">
                <field name="prs_expense_concept_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
