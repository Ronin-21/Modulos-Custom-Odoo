<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- =========================================================
         Reporte de ingresos - Account Reports (Enterprise)
         ========================================================= -->

    <record id="prs_income_account_report" model="account.report">
        <field name="name">Reporte de ingresos</field>

        <!-- Native report topbar controls -->
        <field name="search_bar" eval="True"/>
        <field name="filter_date_range" eval="True"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_partner" eval="True"/>
        <field name="filter_show_draft" eval="True"/>

                <field name="filter_unfold_all" eval="True"/>
<!-- Custom handler -->
        <field name="custom_handler_model_id" ref="payment_register_statement.model_prs_income_account_report_handler"/>

        <!-- Columns -->
        <field name="column_ids" eval="[
            (5, 0, 0),
            (0, 0, {'name': 'Fecha', 'expression_label': 'date', 'sequence': 10}),
            (0, 0, {'name': 'Cód. Cli', 'expression_label': 'customer_code', 'sequence': 20}),
            (0, 0, {'name': 'Cliente', 'expression_label': 'partner', 'sequence': 30}),
            (0, 0, {'name': 'Diario', 'expression_label': 'journal', 'sequence': 40}),
            (0, 0, {'name': 'Método', 'expression_label': 'method', 'sequence': 50}),
            (0, 0, {'name': 'Detalle', 'expression_label': 'detail', 'sequence': 60}),
            (0, 0, {'name': 'Importe', 'expression_label': 'amount', 'sequence': 70, 'figure_type': 'monetary'}),
        ]"/>
    </record>

    <!-- Action -->
    <record id="action_prs_income_account_report" model="ir.actions.client">
        <field name="name">Reporte de ingresos</field>
        <field name="tag">account_report</field>
        <field name="context" eval="{'report_id': ref('payment_register_statement.prs_income_account_report')}"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_prs_income_account_report"
              name="Reporte de ingresos"
              parent="payment_register_statement.menu_prs_reports_management"
              action="action_prs_income_account_report"
              sequence="261"/>
</odoo>
