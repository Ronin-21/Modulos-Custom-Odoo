<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- =========================================================
         Reporte de gastos (vista nativa de pagos: buscador estándar)
         ========================================================= -->

    <record id="view_prs_expense_payment_tree" model="ir.ui.view">
        <field name="name">account.payment.tree.prs.expense.report</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list string="Reporte de gastos" create="0" edit="0" delete="0" default_order="date desc, id desc">
                <field name="date"/>
                <field name="name" string="Número"/>
                <field name="journal_id" string="Diario"/>
                <field name="payment_method_line_id" string="Método de pago"/>
                <field name="partner_id" string="Contacto"/>
                <field name="prs_expense_concept_id" string="Concepto"/>
                <field name="memo" string="Detalle"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_prs_expense_report_payments" model="ir.actions.act_window">
        <field name="name">Reporte de gastos</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_prs_expense_payment_tree"/>
        <!-- Solo egresos (pagos realizados). Evitamos transferencias internas. -->
        <field name="domain">[('payment_type','=','outbound'), ('is_internal_transfer','=',False)]</field>
        <!-- El buscador es el nativo de pagos (account.view_account_payment_search) y nuestro inherit agrega Conceptos/Gastos Varios -->
        <field name="context">{'default_payment_type': 'outbound'}</field>
    </record>

    <menuitem id="menu_prs_expense_report_single"
              name="Reporte de gastos"
              parent="account.menu_finance_reports"
              action="action_prs_expense_report_payments"
              sequence="90"/>

</odoo>
