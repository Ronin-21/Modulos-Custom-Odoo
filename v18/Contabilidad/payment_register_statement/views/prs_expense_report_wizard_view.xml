<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_prs_expense_report_wizard_form" model="ir.ui.view">
        <field name="name">prs.expense.report.wizard.form</field>
        <field name="model">prs.expense.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Imprimir Gastos / Compras">
                <group>
                    <field name="group_mode"/>
                    <field name="order"/>
                </group>

                <group string="Resumen" col="4">
                    <field name="payment_count" readonly="1"/>
                    <field name="date_from" readonly="1"/>
                    <field name="date_to" readonly="1"/>
                    <field name="total_amount" readonly="1"/>
                </group>

                <footer>
                    <button name="action_print_pdf" type="object"
                            string="Imprimir PDF" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
