<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_prs_accreditation_confirm_wizard" model="ir.ui.view">
        <field name="name">prs.accreditation.confirm.wizard.form</field>
        <field name="model">prs.accreditation.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Acreditaciones pendientes">
                <sheet>
                    <div class="oe_title">
                        <h3>
                            Acreditaciones pendientes en
                            <field name="journal_id" readonly="1" nolabel="1"/>
                        </h3>
                    </div>
                    <group>
                        <group>
                            <field name="flow_count" string="Seleccionadas"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_gross_amount" string="Bruto"/>
                            <field name="total_net_amount" string="Neto a acreditar"/>
                        </group>
                    </group>

                    <div class="alert alert-success text-center" invisible="flow_count != 0">
                        <i class="fa fa-check-circle me-1"/>
                        No hay acreditaciones pendientes para este diario.
                    </div>

                    <field name="flow_ids"
                           invisible="flow_count == 0"
                           widget="many2many"
                           nolabel="1"
                           readonly="1"
                           options="{'no_create': True}">
                        <list string="Acreditaciones pendientes" create="0" delete="1">
                            <field name="expected_date" string="Fecha esperada"/>
                            <field name="label" string="Etiqueta"/>
                            <field name="card_label" string="Tarjeta"/>
                            <field name="plan_label" string="Plan"/>
                            <field name="amount_gross" string="Bruto"/>
                            <field name="fee_amount" string="Comisión"/>
                            <field name="fee_tax_amount" string="IVA comisión"/>
                            <field name="withholding_amount" string="Retenciones"/>
                            <field name="amount_signed" string="Neto acreditado"/>
                            <field name="state" string="Estado"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm_selected"
                            type="object"
                            string="Confirmar acreditaciones"
                            class="btn-primary"
                            invisible="flow_count == 0"
                            confirm="¿Confirmar las acreditaciones seleccionadas? Se crearán los extractos en el diario destino."/>
                    <button name="action_confirm_all"
                            type="object"
                            string="Confirmar todas"
                            class="btn-secondary"
                            invisible="flow_count == 0"
                            confirm="¿Confirmar todas las acreditaciones pendientes del diario?"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_prs_accreditation_confirm_wizard" model="ir.actions.act_window">
        <field name="name">Acreditaciones pendientes</field>
        <field name="res_model">prs.accreditation.confirm.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_prs_accreditation_confirm_wizard"/>
        <field name="target">new</field>
    </record>

</odoo>
