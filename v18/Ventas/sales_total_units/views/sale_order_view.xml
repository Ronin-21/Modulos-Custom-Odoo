<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_total_units" model="ir.ui.view">
        <field name="name">sale.order.form.total.units</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Total de Litros: SIEMPRE visible -->
            <xpath expr="//group[@name='sale_total']/field[@name='tax_totals']" position="before">
                <field name="volume_discount_enabled" invisible="1"/>
                <!-- Total de Litros -->
                <div class="d-flex justify-content-between">
                    <span class="o_form_label">Total de Litros</span>
                    <span class="o_form_field o_form_value">
                        <field name="x_total_units" readonly="1" nolabel="1" class="o_field_number"/>
                    </span>
                    <span>L</span>
                </div>

                <!-- Descuento por Volumen: SOLO cuando está habilitado en Ajustes -->
                <div class="d-flex justify-content-between mt-1" groups="sales_total_units.group_volume_discount_feature" invisible="not volume_discount_enabled">
                    <span class="o_form_label">Descuento por Volumen</span>
                    <span class="o_form_field o_form_value">
                        <field name="discount_global" readonly="1" nolabel="1" class="o_field_number"/>
                    </span>
                    <span>%</span>
                </div>
            </xpath>

        </field>
    </record>
</odoo>
