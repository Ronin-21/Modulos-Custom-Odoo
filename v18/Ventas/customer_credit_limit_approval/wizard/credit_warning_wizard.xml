<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_credit_warning_wizard_form" model="ir.ui.view">
        <field name="name">credit.warning.wizard.form</field>
        <field name="model">credit.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Advertencia de Crédito">
                <div class="alert alert-warning" role="alert">
                    <h4>⚠️ Monto de Advertencia de Crédito Superado</h4>
                    <p>
                        Esta orden supera el <strong>monto de advertencia</strong> de crédito del
                        cliente por: <strong><field name="excess_warning"/></strong>
                    </p>
                    <p>¿Desea confirmar la orden de todas formas?</p>
                </div>
                <footer>
                    <button string="✅ Confirmar de todas formas"
                            name="action_confirm_anyway"
                            type="object"
                            class="btn-primary"/>
                    <button string="❌ Cancelar"
                            name="action_cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
