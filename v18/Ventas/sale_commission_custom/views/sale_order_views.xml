<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Smart button en la orden de venta -->
    <record id="view_sale_order_commission_button" model="ir.ui.view">
        <field name="name">sale.order.commission.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="action_view_commissions"
                        icon="fa-percent"
                        invisible="commission_count == 0">
                    <field name="commission_count" widget="statinfo"
                           string="Comisiones"/>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Pestaña propia de comisiones en el formulario de orden -->
    <record id="view_sale_order_commission_tab" model="ir.ui.view">
        <field name="name">sale.order.commission.tab</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Comisiones"
                      name="commission_tab"
                      groups="sale_commission_custom.group_commission_salesperson">
                    <group>
                        <field name="commission_state" readonly="1"/>
                        <field name="commission_amount_total" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>