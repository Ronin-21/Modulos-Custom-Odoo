<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        FIX: Vista faltante para los campos de comisión en el formulario de usuario.
        Los campos commission_percent y use_custom_commission existían en el modelo
        res.users pero no estaban expuestos en ninguna vista, haciendo imposible
        configurar el porcentaje personalizado por vendedor desde la interfaz.
    -->
    <record id="view_users_commission_form" model="ir.ui.view">
        <field name="name">res.users.commission.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Comisiones" name="commission_tab"
                      groups="sale_commission_custom.group_commission_admin">
                    <group string="Configuración de comisión">
                        <field name="use_custom_commission" widget="boolean_toggle"/>
                        <field name="commission_percent"
                               invisible="not use_custom_commission"
                               required="use_custom_commission"/>
                    </group>
                    <group string="Ayuda" invisible="use_custom_commission">
                        <div class="text-muted">
                            Este vendedor usará el porcentaje por defecto
                            configurado en <strong>Comisiones → Configuración</strong>.
                            Activá "Usar comisión personalizada" para asignarle
                            un porcentaje propio.
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
