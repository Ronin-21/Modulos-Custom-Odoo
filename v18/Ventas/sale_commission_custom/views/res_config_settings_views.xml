<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_commission" model="ir.ui.view">
        <field name="name">res.config.settings.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='sale_settings']" position="after">
                <h2>Comisiones de vendedores</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_right_pane">
                            <label string="Configuración de comisiones"/>
                            <div class="text-muted">
                                Configure porcentajes, base de cálculo
                                y comportamiento con notas de crédito.
                            </div>
                            <div class="content-group mt8">
                                <button type="object"
                                        name="action_open_commission_config"
                                        string="Configurar comisiones"
                                        class="btn btn-secondary"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
