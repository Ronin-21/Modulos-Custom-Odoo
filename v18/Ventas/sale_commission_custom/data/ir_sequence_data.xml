<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_commission_line" model="ir.sequence">
            <field name="name">Comisión de vendedor</field>
            <field name="code">sale.commission.line</field>
            <field name="prefix">COM/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_commission_settlement" model="ir.sequence">
            <field name="name">Liquidación de comisiones</field>
            <field name="code">sale.commission.settlement</field>
            <field name="prefix">LIQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="ir_cron_generate_missing_commissions" model="ir.cron">
            <field name="name">Comisiones: generar faltantes</field>
            <field name="model_id" ref="model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_missing_commissions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>