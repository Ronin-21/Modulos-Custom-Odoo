<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_commission_settlement_wizard_form"
            model="ir.ui.view">
        <field name="name">sale.commission.settlement.wizard.form</field>
        <field name="model">sale.commission.settlement.wizard</field>
        <field name="arch" type="xml">
            <form string="Nueva liquidación de comisiones">
                <group>
                    <group string="Criterios">
                        <field name="salesperson_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="company_id"
                               groups="base.group_multi_company"/>
                    </group>
                    <group string="Vista previa">
                        <field name="preview_count" readonly="1"/>
                        <field name="preview_amount" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_settlement"
                            string="Crear liquidación"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_commission_settlement_wizard"
            model="ir.actions.act_window">
        <field name="name">Nueva liquidación</field>
        <field name="res_model">sale.commission.settlement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>