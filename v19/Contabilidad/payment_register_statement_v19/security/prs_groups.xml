<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="privilege_prs_assign_payments_to_statements" model="res.groups.privilege">
        <field name="name">Payment Register Statement</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="sequence">90</field>
    </record>

    <record id="group_prs_assign_payments_to_statements" model="res.groups">
        <field name="name">Asignar pagos a estados de cuenta</field>
        <field name="privilege_id" ref="payment_register_statement_v19.privilege_prs_assign_payments_to_statements"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="privilege_prs_money_flow_enabled" model="res.groups.privilege">
        <field name="name">Flujo de Pagos</field>
        <field name="category_id" ref="base.module_category_accounting"/>
        <field name="sequence">91</field>
    </record>

    <record id="group_prs_money_flow_enabled" model="res.groups">
        <field name="name">Flujo de Pagos</field>
        <field name="privilege_id" ref="payment_register_statement_v19.privilege_prs_money_flow_enabled"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

</odoo>
