<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form_ar_withholding_amount_editable" model="ir.ui.view">
        <field name="name">account.payment.register.form.ar.withholding.amount.editable</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="l10n_ar_withholding.view_account_payment_register_form"/>
        <field name="arch" type="xml">

            <!--
                Reemplazamos la columna "Cantidad" (campo compute readonly)
                por x_manual_amount_value, que arranca con el cálculo automático
                y el usuario puede modificarlo libremente.
            -->
            <xpath expr="//field[@name='l10n_ar_withholding_ids']//list//field[@name='amount']" position="replace">
                <field name="x_manual_amount_value" string="Cantidad"/>
            </xpath>

        </field>
    </record>
</odoo>