<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_installation_withdrawal" model="ir.actions.report">
        <field name="name">Comprobante de retiro</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_installation_material_control.report_installation_withdrawal_document</field>
        <field name="report_file">sale_installation_material_control.report_installation_withdrawal_document</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Retiro - %s' % (object.name)</field>
    </record>

    <record id="action_report_installation_return" model="ir.actions.report">
        <field name="name">Comprobante de devolución</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_installation_material_control.report_installation_return_document</field>
        <field name="report_file">sale_installation_material_control.report_installation_return_document</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Devolución - %s' % (object.name)</field>
    </record>

</odoo>
