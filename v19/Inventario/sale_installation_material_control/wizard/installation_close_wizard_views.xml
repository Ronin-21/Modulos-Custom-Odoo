<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_installation_close_wizard_form" model="ir.ui.view">
        <field name="name">installation.close.wizard.form</field>
        <field name="model">installation.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Cerrar consumo de materiales">
                <field name="installation_id" invisible="1"/>
                <field name="allow_close_with_installer_material" invisible="1"/>
                <div class="alert alert-info" role="status">
                    Al cerrar se consume el material en poder del instalador, se libera el sobrante
                    a stock libre y se ajusta la venta al consumo real.
                </div>
                <field name="line_ids">
                    <list create="false" delete="false" edit="false">
                        <field name="product_id"/>
                        <field name="original_qty"/>
                        <field name="used_qty" sum="Usado real"/>
                        <field name="released_qty" sum="Liberado"/>
                    </list>
                </field>
                <group>
                    <field name="adjust_so_qty"/>
                    <field name="in_installer_total"/>
                    <field name="confirm_installer_material"
                           invisible="in_installer_total &lt;= 0 or allow_close_with_installer_material"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Cerrar instalación"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
