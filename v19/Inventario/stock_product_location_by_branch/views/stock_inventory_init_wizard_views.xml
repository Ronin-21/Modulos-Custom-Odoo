<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════
         Vista formulario del asistente
    ════════════════════════════════════════════════════════════════════ -->
    <record id="view_stock_inventory_init_wizard_form" model="ir.ui.view">
        <field name="name">stock.inventory.init.wizard.form</field>
        <field name="model">stock.inventory.init.wizard</field>
        <field name="arch" type="xml">
            <form string="Preparar Ajuste de Inventario">
                <sheet>
                    <div class="oe_title">
                        <h2>Preparar Ajuste de Inventario desde Configuración</h2>
                    </div>
                    <p class="text-muted">
                        Este asistente crea o marca las líneas de Inventario Físico para todos los
                        productos configurados en "Ubicaciones por Producto/Sucursal".
                        Los productos sin stock aparecerán con cantidad 0; usted ingresará
                        el conteo real antes de aplicar.
                    </p>
                    <group>
                        <group string="Filtros">
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="warehouse_ids"
                                   widget="many2many_tags"/>
                        </group>
                        <group string="Resumen">
                            <field name="config_count" readonly="1"/>
                            <field name="existing_quant_count" readonly="1"/>
                            <field name="new_quant_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_prepare"
                            type="object"
                            string="Preparar Ajuste de Inventario"
                            class="btn-primary"
                            invisible="config_count == 0"/>
                    <button special="cancel"
                            string="Cancelar"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Acción de ventana para abrir el asistente
    ════════════════════════════════════════════════════════════════════ -->
    <record id="action_stock_inventory_init_wizard" model="ir.actions.act_window">
        <field name="name">Preparar Ajuste de Inventario</field>
        <field name="res_model">stock.inventory.init.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Server action vinculado al modelo (aparece en el menú ⚙ de la lista)
    ════════════════════════════════════════════════════════════════════ -->
    <record id="action_splb_open_inventory_wizard" model="ir.actions.server">
        <field name="name">Preparar Ajuste de Inventario</field>
        <field name="model_id" ref="model_stock_product_branch_location"/>
        <field name="binding_model_id" ref="model_stock_product_branch_location"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env.ref('stock_product_location_by_branch.action_stock_inventory_init_wizard').read()[0]
action['context'] = {'default_company_id': env.company.id}
        </field>
        <field name="group_ids" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>

</odoo>
