<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_interbranch_transfer_wizard_form" model="ir.ui.view">
        <field name="name">stock.interbranch.transfer.wizard.form</field>
        <field name="model">stock.interbranch.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Transferencia Inter-Sucursal">
                <sheet>
                    <div class="oe_title">
                        <h2>Transferencia de Stock entre Sucursales</h2>
                    </div>

                    <!-- ── Estado: borrador ───────────────────────────────────── -->
                    <div invisible="state == 'done'">
                        <group>
                            <p class="text-muted">
                                Seleccione la sucursal <strong>origen</strong> y <strong>destino</strong>,
                                luego agregue los productos a transferir. El sistema creará automáticamente
                                dos transferencias vinculadas usando una ubicación de tránsito, y aplicará
                                las ubicaciones habituales configuradas para cada producto.
                            </p>
                            <group string="Sucursales">
                                <field name="warehouse_src_id" options="{'no_create': True}"/>
                                <field name="warehouse_dst_id" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <separator string="Productos"/>
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="uom_id"/>
                            </list>
                        </field>
                    </div>

                    <!-- ── Estado: creado ─────────────────────────────────────── -->
                    <group invisible="state == 'draft'">
                        <p class="text-muted">
                            Las transferencias fueron creadas correctamente.
                            Validá primero la <strong>transferencia de salida</strong> (origen → tránsito)
                            y luego la <strong>transferencia de entrada</strong> (tránsito → destino).
                        </p>
                        <group string="Transferencias generadas">
                            <field name="picking_src_id" readonly="1" string="Salida (origen → tránsito)"/>
                            <field name="picking_dst_id" readonly="1" string="Entrada (tránsito → destino)"/>
                        </group>
                    </group>

                    <field name="state" invisible="1"/>
                </sheet>

                <footer>
                    <button name="action_create_transfers"
                            type="object"
                            string="Crear Transferencias"
                            class="btn-primary"
                            invisible="state == 'done'"/>

                    <button name="action_open_src_picking"
                            type="object"
                            string="Ver Transferencia Salida"
                            class="btn-primary"
                            invisible="state == 'draft' or not picking_src_id"/>

                    <button name="action_open_dst_picking"
                            type="object"
                            string="Ver Transferencia Entrada"
                            class="btn-secondary"
                            invisible="state == 'draft' or not picking_dst_id"/>

                    <button special="cancel"
                            string="Cerrar"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_interbranch_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Transferencia Inter-Sucursal</field>
        <field name="res_model">stock.interbranch.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_stock_interbranch_transfer_wizard"
        name="Transferencia entre Sucursales"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_stock_interbranch_transfer_wizard"
        sequence="99"
        groups="stock.group_stock_manager"/>

</odoo>
