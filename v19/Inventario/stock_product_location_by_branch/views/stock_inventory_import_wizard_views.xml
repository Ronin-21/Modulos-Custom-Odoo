<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════
         Vista formulario del importador
    ════════════════════════════════════════════════════════════════════ -->
    <record id="view_stock_inventory_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.inventory.import.wizard.form</field>
        <field name="model">stock.inventory.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importación Masiva de Inventario">
                <sheet>
                    <div class="oe_title">
                        <h2>Importación Masiva desde CSV / Excel</h2>
                    </div>

                    <!-- ── Estado: carga ─────────────────────────────────────── -->
                    <group invisible="state == 'done'">
                        <p class="text-muted">
                            Cargue un archivo con tres columnas: <strong>Código de Producto</strong>,
                            <strong>Ubicación</strong> (nombre completo, ej: DP-CO/Existencias/Pasillo 1)
                            y <strong>Cantidad</strong>. La primera fila puede ser un encabezado.
                            El sistema creará la configuración producto→almacén y preparará el Inventario Físico.
                        </p>
                        <group string="Destino">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group string="Archivo">
                            <field name="import_file" filename="import_filename" widget="binary"/>
                            <field name="import_filename" invisible="1"/>
                        </group>
                        <group string="Plantilla de ejemplo" invisible="template_file">
                            <div>
                                <button name="action_download_template"
                                        type="object"
                                        string="Descargar Plantilla Excel"
                                        class="btn-secondary"/>
                            </div>
                        </group>
                        <group string="Plantilla generada" invisible="not template_file">
                            <field name="template_file"
                                   filename="template_filename"
                                   widget="binary"
                                   readonly="1"
                                   string="Descargar"/>
                            <field name="template_filename" invisible="1"/>
                        </group>
                    </group>

                    <!-- ── Estado: resultados ────────────────────────────────── -->
                    <group invisible="state == 'draft'">
                        <group string="Configuraciones (producto → almacén)">
                            <field name="result_new_configs" readonly="1"/>
                            <field name="result_existing_configs" readonly="1"/>
                        </group>
                        <group string="Inventario (stock.quant)">
                            <field name="result_new_quants" readonly="1"/>
                            <field name="result_updated_quants" readonly="1"/>
                        </group>
                        <group string="Errores / Advertencias"
                               colspan="2"
                               invisible="not result_errors">
                            <field name="result_errors"
                                   readonly="1"
                                   nolabel="1"
                                   widget="text"/>
                        </group>
                    </group>

                    <field name="state" invisible="1"/>
                </sheet>

                <footer>
                    <!-- Botón principal: importar -->
                    <button name="action_import"
                            type="object"
                            string="Importar"
                            class="btn-primary"
                            invisible="state == 'done'"/>

                    <!-- Botón post-importación: ir al Inventario Físico -->
                    <button name="action_open_inventory"
                            type="object"
                            string="Ir al Inventario Físico"
                            class="btn-primary"
                            invisible="state == 'draft' or not result_quant_ids"/>

                    <button special="cancel"
                            string="Cerrar"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Acción de ventana
    ════════════════════════════════════════════════════════════════════ -->
    <record id="action_stock_inventory_import_wizard" model="ir.actions.act_window">
        <field name="name">Importación Masiva de Inventario</field>
        <field name="res_model">stock.inventory.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Server action: aparece en el menú ⚙ de la lista de configuraciones
    ════════════════════════════════════════════════════════════════════ -->
    <record id="action_splb_open_import_wizard" model="ir.actions.server">
        <field name="name">Importar desde CSV/Excel</field>
        <field name="model_id" ref="model_stock_product_branch_location"/>
        <field name="binding_model_id" ref="model_stock_product_branch_location"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env.ref('stock_product_location_by_branch.action_stock_inventory_import_wizard').read()[0]
action['context'] = {'default_company_id': env.company.id}
        </field>
        <field name="group_ids" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>

</odoo>
