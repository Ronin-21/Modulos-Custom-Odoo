<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_auto_update_cost_v19" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.auto.update.cost.v19</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Precio de Costo Automático" name="auto_update_cost_v19">
                    <block title="Actualización automática del costo de productos" class="o_settings_container">

                        <setting id="auc_enabled" string="Activar módulo">
                            <field name="auto_update_cost_enabled"/>
                        </setting>

                        <div class="content-group" invisible="auto_update_cost_enabled == False">

                            <!-- ── Standard ───────────────────────────────── -->
                            <h2 class="mt16">Productos con costo Standard</h2>

                            <setting id="auc_standard_moment"
                                     string="Momento de actualización">
                                <field name="auto_update_cost_moment" widget="radio" class="o_light_label"/>
                                <div class="text-muted mt8">
                                    "Al validar la factura" funciona tanto para facturas generadas
                                    desde una Orden de Compra como para facturas de proveedor
                                    creadas directamente.
                                </div>
                            </setting>

                            <setting id="auc_standard_strategy"
                                     string="Estrategia">
                                <field name="auto_update_cost_standard_strategy" widget="radio" class="o_light_label"/>
                                <div class="text-muted mt8">
                                    "Promedio simple" = promedio aritmético de precios de compra/factura
                                    registrados por el módulo, sin ponderar por stock ni cantidades.
                                </div>
                            </setting>

                            <setting id="auc_scope"
                                     string="Alcance multi-empresa">
                                <field name="auto_update_cost_scope" widget="radio" class="o_light_label"/>
                            </setting>

                            <!-- ── AVCO ───────────────────────────────────── -->
                            <h2 class="mt16">Productos con costo Promedio (AVCO)</h2>

                            <setting id="auc_avco_replicate"
                                     string="Replicar promedio real a sucursales">
                                <field name="auto_update_cost_avco_replicate"/>
                                <div class="text-muted mt8">
                                    El costo ponderado real lo calcula Odoo al recibir stock
                                    (valoración). El módulo replica ese resultado a las otras
                                    compañías al validar la recepción o la factura según el
                                    momento elegido.
                                </div>
                            </setting>

                            <!-- ── Cambios manuales ───────────────────────── -->
                            <h2 class="mt16">Cambios manuales de costo</h2>

                            <setting id="auc_manual_propagate"
                                     string="Propagar cambios manuales entre compañías">
                                <field name="auto_update_cost_propagate_manual_cost"/>
                                <div class="text-muted mt8">
                                    Por seguridad, por defecto se propaga solo en Standard.
                                </div>
                                <div class="content-group mt8"
                                     invisible="auto_update_cost_propagate_manual_cost == False">
                                    <field name="auto_update_cost_propagate_manual_cost_include_avco"/>
                                    <label for="auto_update_cost_propagate_manual_cost_include_avco"
                                           string="Permitir también en AVCO (NO recomendado)"/>
                                </div>
                            </setting>

                            <!-- ── BoM ────────────────────────────────────── -->
                            <h2 class="mt16">Lista de Materiales (BoM)</h2>

                            <setting id="auc_bom"
                                     string="Recalcular BoM al actualizar costo de componente">
                                <field name="auto_update_cost_recalc_bom"/>
                                <div class="text-muted mt8">
                                    Requiere módulo MRP instalado. Recalcula el costo del
                                    producto final considerando eficiencia/merma de la BoM.
                                </div>
                            </setting>

                        </div>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
