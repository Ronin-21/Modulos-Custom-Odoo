<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_credit_statement_wizard_form" model="ir.ui.view">
        <field name="name">credit.statement.wizard.form</field>
        <field name="model">credit.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Estado de Cuenta">
                <field name="partner_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>

                <group string="Resumen de Crédito">
                    <group>
                        <field name="credit_warning" readonly="1"/>
                        <field name="credit_blocking" readonly="1"/>
                    </group>
                    <group>
                        <field name="amount_due_accounting" readonly="1"/>
                        <field name="amount_due_sale" readonly="1"/>
                        <field name="amount_due" readonly="1" class="fw-bold"/>
                        <field name="utilization_pct" readonly="1" string="Utilización %"
                               widget="percentpie"/>
                    </group>
                </group>

                <footer>
                    <button name="action_print" string="Imprimir PDF"
                            type="object" class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
