<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <!-- v19: las categorías de grupos se modelan con res.groups.privilege -->
    <record id="credit_privilege" model="res.groups.privilege">
      <field name="name">Crédito</field>
      <field name="category_id" ref="base.module_category_sales_sales"/>
    </record>

    <record id="group_credit_approver" model="res.groups">
      <field name="name">Aprobador de Límite de Crédito</field>
      <field name="privilege_id" ref="credit_privilege"/>
      <field name="comment">Permite aprobar, rechazar y volver a borrador órdenes de venta bloqueadas por límite de crédito.</field>
    </record>
  </data>
</odoo>
