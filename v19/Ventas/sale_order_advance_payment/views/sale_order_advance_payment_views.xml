<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- =====================================================
         VISTAS: sale.order.advance.payment
         ===================================================== -->

    <!-- Vista Lista -->
    <record id="view_sale_order_advance_payment_tree" model="ir.ui.view">
        <field name="name">sale.order.advance.payment.tree</field>
        <field name="model">sale.order.advance.payment</field>
        <field name="arch" type="xml">
            <list string="Pagos Adelantados" decoration-success="state == 'applied'"
                  decoration-info="state == 'posted'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="payment_date"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="journal_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'applied'"
                       decoration-info="state == 'posted'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="invoice_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario -->
    <record id="view_sale_order_advance_payment_form" model="ir.ui.view">
        <field name="name">sale.order.advance.payment.form</field>
        <field name="model">sale.order.advance.payment</field>
        <field name="arch" type="xml">
            <form string="Pago Adelantado" create="false" delete="false">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="posted,applied,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Origen">
                            <field name="sale_order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="company_id" readonly="1"
                                   groups="base.group_multi_company"/>
                        </group>
                        <group string="Pago">
                            <field name="amount" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="payment_date" readonly="1"/>
                            <field name="journal_id" readonly="1"/>
                            <field name="payment_method_line_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Referencias">
                            <field name="reference" readonly="1"/>
                            <field name="payment_count" invisible="1"/>
                            <field name="payment_id" readonly="1"
                                   string="Pago Principal"
                                   invisible="payment_count &gt; 1"/>
                            <field name="invoice_id" readonly="1"/>
                        </group>
                        <group string="Registrado por">
                            <field name="create_uid" readonly="1"/>
                        </group>
                    </group>
                    <group string="Pagos Contables" invisible="payment_count &lt;= 1">
                        <field name="payment_ids" readonly="1" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="journal_id"/>
                                <field name="payment_method_line_id"/>
                                <field name="amount"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </group>
                    <group string="Notas">
                        <field name="note" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de ventana -->
    <record id="action_sale_order_advance_payment" model="ir.actions.act_window">
        <field name="name">Pagos Adelantados</field>
        <field name="res_model">sale.order.advance.payment</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay pagos adelantados registrados
            </p>
            <p>
                Los pagos adelantados se registran desde las Órdenes de Venta confirmadas.
            </p>
        </field>
    </record>

    <!-- Entrada de menú (bajo Ventas > Pagos) -->
    <menuitem
        id="menu_sale_advance_payments"
        name="Pagos Adelantados"
        parent="sale.menu_sale_order"
        action="action_sale_order_advance_payment"
        sequence="50"
        groups="account.group_account_user,sales_team.group_sale_salesman_all_leads"/>
</odoo>
