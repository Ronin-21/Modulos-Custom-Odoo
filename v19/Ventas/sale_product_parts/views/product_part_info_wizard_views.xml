<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_part_info_wizard_form_view" model="ir.ui.view">
        <field name="name">product.part.info.wizard.form</field>
        <field name="model">product.part.info.wizard</field>
        <field name="arch" type="xml">

            <form string="Información de la Pieza">
                <sheet>

                    <div class="oe_title mb-3">
                        <h4 class="text-muted mb-0">Pieza / Repuesto</h4>
                        <h2>
                            <field name="product_id" readonly="1"
                                   options="{'no_open': True}" nolabel="1"/>
                        </h2>
                    </div>

                    <!-- Contexto oculto para action_go_back -->
                    <field name="part_id" invisible="1"/>
                    <field name="product_tmpl_id" invisible="1"/>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="origin_line_id" invisible="1"/>
                    <field name="parent_product_name" invisible="1"/>
                    <field name="has_stock_module" invisible="1"/>

                    <group>
                        <group string="Identificación">
                            <field name="product_ref" readonly="1"
                                   invisible="not product_ref"/>
                            <field name="barcode" readonly="1"
                                   invisible="not barcode"/>
                            <field name="categ_id" readonly="1"
                                   string="Categoría"
                                   options="{'no_open': True}"/>
                            <field name="uom_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="product_type" readonly="1"
                                   invisible="not product_type"/>
                        </group>
                        <group string="Precios">
                            <field name="list_price" readonly="1"
                                   string="Precio de venta" widget="monetary"/>
                            <field name="standard_price" readonly="1"
                                   string="Costo" widget="monetary"/>
                        </group>
                    </group>

                    <group invisible="not has_stock_module">
                        <group string="Stock">
                            <field name="qty_available" readonly="1"
                                   string="Disponible"/>
                            <field name="virtual_available" readonly="1"
                                   string="Cantidad prevista"/>
                            <field name="qty_in" readonly="1"
                                   string="Entradas pendientes"/>
                            <field name="qty_out" readonly="1"
                                   string="Salidas pendientes"/>
                        </group>
                        <group string="En el despiece">
                            <field name="quantity_suggested" readonly="1"
                                   string="Cantidad sugerida"/>
                            <field name="note" readonly="1"
                                   invisible="not note"/>
                        </group>
                    </group>

                    <!--
                        Tabla HTML de ubicaciones: no tiene filas clickeables.
                        No genera ningún popup al interactuar con ella.
                        Solo visible si Inventario está instalado y hay datos.
                    -->
                    <div invisible="not has_stock_module">
                        <h6 style="font-weight:600; margin-bottom:8px; color:#555;">
                            STOCK POR UBICACIÓN
                        </h6>
                        <field name="location_html" readonly="1" nolabel="1"/>
                    </div>

                    <div class="alert alert-info mt-2" invisible="has_stock_module">
                        <i class="fa fa-info-circle mr-1"/>
                        El módulo de <strong>Inventario</strong> no está instalado.
                    </div>

                </sheet>

                <footer>
                    <button name="action_go_back"
                            type="object"
                            string="← Volver al despiece"
                            class="btn-primary"/>
                    <button string="Cerrar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>

        </field>
    </record>

</odoo>
