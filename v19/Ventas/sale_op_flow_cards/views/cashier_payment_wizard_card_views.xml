<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cashier_payment_wizard_form_prs_card" model="ir.ui.view">
        <field name="name">sale.cashier.payment.wizard.form.prs.card</field>
        <field name="model">sale.cashier.payment.wizard</field>
        <field name="inherit_id" ref="sale_op_flow.view_cashier_payment_wizard_form"/>
        <field name="arch" type="xml">
            <!-- Agregar columnas de tarjeta en la seccion Banco / Transferencia -->
            <xpath expr="//field[@name='bank_line_ids']//field[@name='financing_plan_id']" position="after">
                <field name="prs_card_provider_id" column_invisible="1"/>
                <field name="prs_card_id"
                       optional="show"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="prs_installment_id"
                       optional="show"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="amount_base"
                       string="Monto base"
                       optional="show"
                       readonly="parent.payment_mode == 'single'"
                       force_save="1"/>
            </xpath>
            <!-- Hacer readonly "A cobrar" cuando hay plan de cuotas (se calcula desde Monto base) -->
            <!-- force_save asegura que el valor calculado por onchange se guarde aunque el campo sea readonly -->
            <xpath expr="//field[@name='bank_line_ids']//field[@name='amount']" position="attributes">
                <attribute name="readonly">prs_installment_id</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
        </field>
    </record>

</odoo>
