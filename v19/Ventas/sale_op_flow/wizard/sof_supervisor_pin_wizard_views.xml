<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sof_supervisor_pin_wizard_form" model="ir.ui.view">
        <field name="name">sof.supervisor.pin.wizard.form</field>
        <field name="model">sof.supervisor.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Autorización de supervisor">
                <div class="alert alert-warning" role="alert">
                    Esta acción requiere la autorización de un <strong>supervisor</strong>.
                    Pedile que ingrese su PIN para continuar.
                </div>
                <group>
                    <field name="order_id" invisible="1"/>
                    <field name="action_type" invisible="1"/>
                    <field name="supervisor_pin" password="True"
                           placeholder="PIN del supervisor"/>
                </group>
                <footer>
                    <button name="action_authorize" string="Autorizar"
                            type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
