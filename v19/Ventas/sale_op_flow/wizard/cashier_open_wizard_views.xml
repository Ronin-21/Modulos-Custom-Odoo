<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cashier_open_wizard_form" model="ir.ui.view">
        <field name="name">sale.cashier.open.wizard.form</field>
        <field name="model">sale.cashier.open.wizard</field>
        <field name="arch" type="xml">
            <form string="Apertura de Sesión de Caja" class="o_cashier_open_wizard">
                <sheet>
                    <!-- Campos técnicos ocultos -->
                    <field name="carry_over_source_session_id" invisible="1"/>
                    <field name="carry_over_amount_proposed" invisible="1"/>
                    <field name="is_supervisor" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="fund_difference" invisible="1"/>

                    <div class="text-center mb-4">
                        <h2>🏪 Apertura de Caja</h2>
                        <p class="text-muted">
                            Ingresá el fondo inicial y confirmá para comenzar a operar.
                        </p>
                    </div>

                    <!-- ── CASO: sin carry-over ─────────────────────────────── -->
                    <group invisible="carry_over_source_session_id">
                        <group string="Cajero">
                            <field name="cashier_id" readonly="1"/>
                            <field name="company_id" readonly="1" invisible="1"/>
                        </group>
                        <group string="Fondo inicial">
                            <field name="initial_fund" widget="monetary"
                                   string="Efectivo en caja al inicio"/>
                        </group>
                    </group>

                    <!-- ── CASO: con carry-over ───────────────────────────────
                         Tres sub-casos:
                         A) Cajero (bloqueado)
                         B) Supervisor sin cambios (informativo)
                         C) Supervisor con ajuste (requiere motivo + contabilidad) -->
                    <div invisible="not carry_over_source_session_id">

                        <!-- A) Cajero: campo bloqueado, mensaje claro -->
                        <div invisible="is_supervisor">
                            <div class="alert alert-info mb-3" role="alert">
                                <strong>💵 Fondo del turno anterior detectado.</strong><br/>
                                El cajón tiene <b>
                                    <field name="carry_over_amount_proposed"
                                           readonly="1" nolabel="1" widget="monetary"/>
                                </b> del cierre anterior.
                                Este fondo fue registrado como fondo inicial
                                y <strong>no puede ser modificado por el cajero</strong>.
                            </div>
                            <group>
                                <group string="Cajero">
                                    <field name="cashier_id" readonly="1"/>
                                    <field name="company_id" readonly="1" invisible="1"/>
                                </group>
                                <group string="Fondo inicial">
                                    <field name="initial_fund" widget="monetary"
                                           string="Efectivo en caja al inicio" readonly="1"/>
                                </group>
                            </group>
                        </div>

                        <!-- B+C) Supervisor -->
                        <div invisible="not is_supervisor">

                            <!-- Panel de carry-over con detalle -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">
                                    💵 Fondo de carry-over del turno anterior
                                </div>
                                <div class="card-body">
                                    <group>
                                        <group>
                                            <field name="carry_over_amount_proposed"
                                                   readonly="1"
                                                   string="Retenido al cierre anterior"
                                                   widget="monetary"/>
                                            <field name="carry_over_source_session_id"
                                                   readonly="1"
                                                   string="Sesión de origen"
                                                   options="{'no_open': True}"/>
                                        </group>
                                        <group string="Cajero">
                                            <field name="cashier_id" readonly="1"/>
                                            <field name="company_id" readonly="1" invisible="1"/>
                                        </group>
                                    </group>
                                </div>
                            </div>

                            <!-- Fondo a registrar -->
                            <group string="Fondo a registrar en esta sesión">
                                <group>
                                    <field name="initial_fund" widget="monetary"
                                           string="Efectivo en caja al inicio"/>
                                </group>
                                <group>
                                    <field name="fund_difference" widget="monetary"
                                           string="Diferencia respecto al carry-over"
                                           readonly="1"
                                           invisible="fund_difference == 0"
                                           decoration-danger="fund_difference &lt; 0"
                                           decoration-warning="fund_difference &gt; 0"/>
                                </group>
                            </group>

                            <!-- B) Sin cambios -->
                            <div class="alert alert-success mb-2" role="alert"
                                 invisible="fund_difference != 0">
                                ✅ El fondo coincide con el carry-over. No se requiere ajuste contable.
                            </div>

                            <!-- C1) Reducción: egreso contable -->
                            <div class="alert alert-danger mb-2" role="alert"
                                 invisible="fund_difference >= 0">
                                <strong>⚠️ Fondo menor al carry-over.</strong><br/>
                                La diferencia de <b>
                                    <field name="fund_difference" readonly="1" nolabel="1" widget="monetary"/>
                                </b> se registrará automáticamente como
                                <strong>egreso en el Diario de Efectivo</strong>.
                                Esto refleja el efectivo que salió físicamente del cajón antes de abrir.
                            </div>

                            <!-- C2) Aumento -->
                            <div class="alert alert-warning mb-2" role="alert"
                                 invisible="fund_difference &lt;= 0">
                                <strong>ℹ️ Fondo mayor al carry-over.</strong><br/>
                                Se está agregando efectivo extra al cajón
                                (<b>
                                    <field name="fund_difference" readonly="1" nolabel="1" widget="monetary"/>
                                </b> adicionales).
                            </div>

                            <!-- Motivo: requerido cuando hay diferencia -->
                            <group string="Motivo del ajuste (obligatorio)"
                                   invisible="fund_difference == 0">
                                <field name="carry_over_change_reason"
                                       nolabel="1"
                                       colspan="2"
                                       placeholder="Ej: El cajero entregó el efectivo antes de abrir / Se retiró para depósito / Se agregó fondo extra..."/>
                            </group>

                        </div>
                    </div>

                    <separator string="Nota de apertura (opcional)"/>
                    <field name="opening_notes" nolabel="1"
                           placeholder="Observaciones, novedades del turno..."/>
                </sheet>
                <footer>
                    <button name="action_open_session"
                            type="object"
                            string="✅ Abrir sesión"
                            class="btn-primary btn-lg"/>
                    <button special="cancel" string="Cancelar"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action para abrir el wizard de apertura -->
    <record id="action_cashier_open_wizard" model="ir.actions.act_window">
        <field name="name">Abrir sesión de caja</field>
        <field name="res_model">sale.cashier.open.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
