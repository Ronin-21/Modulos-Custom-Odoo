<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sof_print_wizard_form" model="ir.ui.view">
        <field name="name">sof.print.wizard.form</field>
        <field name="model">sof.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Cobro registrado" js_class="sof_print_wizard_form">
                <field name="order_id" invisible="1"/>
                <field name="invoice_id" invisible="1"/>
                <field name="auto_print" invisible="1"/>
                <div class="text-center p-3">
                    <h5 class="text-success mb-2">
                        ✅ Cobro registrado — <field name="order_name" readonly="1"/>
                    </h5>
                    <p class="text-muted mb-0">¿Desea imprimir la factura?</p>
                </div>
                <footer>
                    <button name="action_print_invoice"
                            type="object"
                            string="Imprimir factura"
                            class="btn-primary"
                            invisible="not invoice_id"/>
                    <button name="action_close"
                            type="object"
                            string="Cerrar"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
