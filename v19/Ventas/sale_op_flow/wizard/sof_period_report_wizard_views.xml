<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sof_period_report_wizard_form" model="ir.ui.view">
        <field name="name">sof.period.report.wizard.form</field>
        <field name="model">sof.period.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Reporte PDF por período">
                <group>
                    <field name="report_type" invisible="1"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="company_id" options="{'no_create': True}"
                           groups="base.group_multi_company"/>
                </group>
                <footer>
                    <button name="action_print" string="Imprimir PDF" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sof_payments_period_wizard" model="ir.actions.act_window">
        <field name="name">Cobros por período (PDF)</field>
        <field name="res_model">sof.period.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'payments'}</field>
    </record>

    <record id="action_sof_sessions_period_wizard" model="ir.actions.act_window">
        <field name="name">Sesiones por período (PDF)</field>
        <field name="res_model">sof.period.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'sessions'}</field>
    </record>
</odoo>
