<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cashier_close_wizard_form" model="ir.ui.view">
        <field name="name">sale.cashier.close.wizard.form</field>
        <field name="model">sale.cashier.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Cierre de Sesión de Caja">
                <sheet>
                    <div class="oe_title"><h2>Rendición de caja</h2></div>
                    <group string="Resumen de la sesión">
                        <group>
                            <field name="session_id" readonly="1"/>
                            <field name="cashier_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_orders" readonly="1"/>
                            <field name="total_collected" readonly="1"/>
                            <field name="opening_balance" readonly="1"/>
                            <field name="total_expected" readonly="1" string="Esperado de rendición"
                                   help="Cobros registrados + fondo inicial de apertura"/>
                        </group>
                    </group>
                    <field name="line_ids" force_save="1">
                        <list editable="bottom" create="0" delete="0">
                            <field name="payment_journal_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                            <field name="amount_expected_original" column_invisible="1" force_save="1"/>
                            <field name="amount_expected" readonly="1" force_save="1" string="Esperado"/>
                            <field name="amount_real" string="Real (ingresado)"/>
                            <field name="difference" readonly="1" string="Diferencia"/>
                            <field name="notes" optional="show"/>
                        </list>
                    </field>
                    <group string="Efectivo para próxima sesión">
                        <group>
                            <field name="carry_over_amount" widget="monetary"
                                   string="Fondo retenido para próximo turno"
                                   help="Ingresá el efectivo que queda en el cajón para el próximo turno. Debe ser menor o igual al efectivo contado. Se propondrá como fondo inicial en la próxima apertura."/>
                        </group>
                        <group>
                            <div class="text-muted small" invisible="carry_over_amount == 0">
                                De lo contado en efectivo, este monto queda en el cajón
                                y el resto se deposita.
                            </div>
                        </group>
                    </group>
                    <group>
                        <group/>
                        <group>
                            <field name="total_expected" readonly="1" string="Esperado"/>
                            <field name="total_real" readonly="1" string="Contado"/>
                            <field name="total_difference" readonly="1" string="Diferencia"
                                   decoration-danger="total_difference != 0"
                                   decoration-success="total_difference == 0"
                                   widget="monetary"/>
                            <field name="carry_over_amount" readonly="1" string="Fondo retenido"
                                   invisible="carry_over_amount == 0"/>
                            <field name="total_deposit" readonly="1" string="A depositar"
                                   invisible="carry_over_amount == 0"
                                   decoration-muted="total_deposit == 0"
                                   widget="monetary"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Observaciones del cajero (diferencias, inconvenientes, etc.)..."/>
                    <div class="alert alert-warning mt-3" role="alert" invisible="total_difference == 0">
                        <strong>⚠️ Diferencia detectada.</strong>
                        Ingresá una observación antes de cerrar. El supervisor deberá validar este cierre.
                    </div>
                </sheet>
                <footer>
                    <button name="action_close_session"
                            string="Cerrar Sesión"
                            type="object"
                            class="btn-primary"
                            confirm="¿Confirmar cierre de la sesión de caja?"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cashier_close_success_wizard_form" model="ir.ui.view">
        <field name="name">sale.cashier.close.success.wizard.form</field>
        <field name="model">sale.cashier.close.success.wizard</field>
        <field name="arch" type="xml">
            <form string="Sesión cerrada">
                <sheet>
                    <div class="oe_title">
                        <h2>Sesión cerrada correctamente</h2>
                    </div>
                    <div class="alert alert-success mb-3" role="alert">
                        La sesión fue cerrada. Podés imprimir el comprobante en el formato que necesites.
                    </div>
                    <group string="Resumen">
                        <group>
                            <field name="session_id" readonly="1"/>
                            <field name="cashier_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_orders" readonly="1"/>
                            <field name="total_collected" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_a4"
                            string="Imprimir A4"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_print_80mm"
                            string="Imprimir 80mm (Comandera)"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_go_to_session"
                            string="Ver sesión"
                            type="object"
                            class="btn-secondary"/>
                    <button string="Cerrar" special="cancel" class="btn-primary ms-auto"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
