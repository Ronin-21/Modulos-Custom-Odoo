<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        noupdate omitido intencionalmente: estos grupos DEBEN actualizarse en cada
        upgrade para que los implied_ids (permisos mínimos) siempre estén vigentes.
    -->
    <data>
        <record id="group_sale_vendor" model="res.groups">
            <field name="name">SOF / Vendedor</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('sales_team.group_sale_salesman')),
                (4, ref('stock.group_stock_user')),
            ]"/>
        </record>

        <record id="group_sale_cashier" model="res.groups">
            <field name="name">SOF / Cajero</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('sales_team.group_sale_salesman')),
                (4, ref('stock.group_stock_user')),
                (4, ref('account.group_account_invoice')),
            ]"/>
        </record>

        <record id="group_sale_dispatch" model="res.groups">
            <field name="name">SOF / Despacho</field>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('sales_team.group_sale_salesman')),
                (4, ref('stock.group_stock_user')),
            ]"/>
        </record>

        <record id="group_sale_supervisor" model="res.groups">
            <field name="name">SOF / Supervisor</field>
            <field name="implied_ids" eval="[
                (4, ref('sale_op_flow.group_sale_vendor')),
                (4, ref('sale_op_flow.group_sale_cashier')),
                (4, ref('sale_op_flow.group_sale_dispatch')),
            ]"/>
        </record>
    </data>
</odoo>
