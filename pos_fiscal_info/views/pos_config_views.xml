<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="pos_config_form_inherit_fiscal_info" model="ir.ui.view">
    <field name="name">pos.config.form.inherit.fiscal.info</field>
    <field name="model">pos.config</field>
    <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <group string="Tickets (Columnas)">
            <field name="show_ticket_col_date"/>
            <field name="show_ticket_col_receipt"/>
            <field name="show_ticket_col_order"/>

            <field name="show_ticket_col_client"/>
            <field name="show_ticket_col_cashier"/>
            <field name="show_ticket_col_total"/>
            <field name="show_ticket_col_coupon"/>
            <field name="show_ticket_col_state"/>
            <field name="show_ticket_col_table"/>

            <separator string="Columnas extra"/>
            <field name="show_ticket_col_payments"/>

            <separator string="Modificaciones"/>
            <field name="show_ticket_receipt_fiscal_info"/>
        </group>
      </xpath>
    </field>
  </record>

</odoo>
