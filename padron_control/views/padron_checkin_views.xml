<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_padron_checkin_tree" model="ir.ui.view">
        <field name="name">padron.checkin.tree</field>
        <field name="model">padron.checkin</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="checkin_datetime"/>
                <field name="event_id"/>
                <field name="person_id"/>
                <field name="mesa_id"/>
                <field name="vote_status"/>
                <field name="vehicle_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_padron_checkin_form" model="ir.ui.view">
        <field name="name">padron.checkin.form</field>
        <field name="model">padron.checkin</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="event_id"/>
                        <field name="person_id"/>
                        <field name="mesa_id" readonly="1"/>
                        <field name="vote_status"/>
                        <field name="vehicle_id"/>
                        <field name="user_id" readonly="1"/>
                        <field name="checkin_datetime" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_padron_checkin" model="ir.actions.act_window">
        <field name="name">Marcaciones de Voto</field>
            <field name="groups_id" eval="[(4, ref('padron_control.group_padron_supervisor')), (4, ref('padron_control.group_padron_admin'))]"/>
        <field name="res_model">padron.checkin</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_padron_checkin" name="Marcaciones de Voto" parent="padron_control.menu_padron_operacion"
              action="action_padron_checkin" sequence="40"
              groups="padron_control.group_padron_supervisor,padron_control.group_padron_admin"/>
</odoo>
